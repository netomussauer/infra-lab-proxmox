# ─────────────────────────────────────────────────────────
# registry-config.yml — Configuração do Docker Registry v2
# Gerenciado pelo Ansible — NÃO edite manualmente.
# Gerado a partir de: templates/registry-config.yml.j2
# Host: {{ inventory_hostname }} ({{ ansible_host }})
# Lab: {{ lab_id }} / {{ environment }}
# ─────────────────────────────────────────────────────────

version: 0.1

log:
  level: warn
  formatter: text
  fields:
    service: registry
    environment: {{ environment }}

storage:
  filesystem:
    rootdirectory: /var/lib/registry
    maxthreads: 100
  delete:
    enabled: true
  cache:
    blobdescriptor: inmemory

http:
  addr: :5000
  relativeurls: false
  headers:
    X-Content-Type-Options: [nosniff]

health:
  storagedriver:
    enabled: true
    interval: 10s
    threshold: 3
