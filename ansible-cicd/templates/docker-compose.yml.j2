---
# ─────────────────────────────────────────────────────────
# docker-compose.yml — Stack CI/CD
# Gerenciado pelo Ansible — NÃO edite manualmente.
# Gerado a partir de: templates/docker-compose.yml.j2
# Host: {{ inventory_hostname }} ({{ ansible_host }})
# Lab: {{ lab_id }} / {{ environment }}
# ─────────────────────────────────────────────────────────

services:

  # ── Gitea — Git server + Gitea Actions CI ──────────────
  gitea:
    image: gitea/gitea:{{ gitea_version }}
    container_name: gitea
    restart: unless-stopped
    ports:
      - "{{ gitea_http_port }}:3000"
      - "{{ gitea_ssh_port }}:22"
    volumes:
      - {{ gitea_data_dir }}:/data
      - /etc/localtime:/etc/localtime:ro
    environment:
      - GITEA__database__DB_TYPE=sqlite3
      - GITEA__server__DOMAIN={{ gitea_domain }}
      - GITEA__server__HTTP_PORT=3000
      - GITEA__server__ROOT_URL=http://{{ gitea_domain }}:{{ gitea_http_port }}/
      - GITEA__server__SSH_PORT={{ gitea_ssh_port }}
      - GITEA__server__SSH_DOMAIN={{ gitea_domain }}
      - GITEA__actions__ENABLED=true
      - GITEA__log__LEVEL=Warn
    deploy:
      resources:
        limits:
          memory: 512M
        reservations:
          memory: 256M
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:3000/"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 60s

  # ── Docker Registry v2 — Registry de imagens de container ──
  registry:
    image: registry:{{ registry_version }}
    container_name: registry
    restart: unless-stopped
    ports:
      - "{{ registry_port }}:5000"
    volumes:
      - {{ registry_data_dir }}:/var/lib/registry
      - {{ docker_compose_dir }}/registry-config.yml:/etc/docker/registry/config.yml:ro
    deploy:
      resources:
        limits:
          memory: 128M
        reservations:
          memory: 64M
    healthcheck:
      test: ["CMD", "wget", "--quiet", "--tries=1", "--spider", "http://localhost:5000/v2/"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 15s
